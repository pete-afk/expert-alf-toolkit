# === SOP Pipeline ===
# Upstage Solar API Key (선택 - 없으면 로컬 임베딩 모델 사용)
UPSTAGE_API_KEY=up_YOUR_API_KEY_HERE

# === QA Agent ===
# Anthropic API Key (Prism Gateway 또는 직접 키)
ANTHROPIC_API_KEY=YOUR_KEY_HERE

# LLM 설정 (선택)
LLM_BASE_URL=https://prism.ch.dev
PERSONA_MODEL=anthropic/claude-sonnet-4-6
JUDGE_MODEL=anthropic/claude-sonnet-4-6
